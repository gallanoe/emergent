{
  "plugins": ["eslint", "oxc", "react", "unicorn", "typescript"],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "no-shadow": "off",
    "no-await-in-loop": "off"
  },
  "ignorePatterns": [
    "dist/",
    "src-tauri/",
    "node_modules/",
    "bun.lock"
  ]
}
