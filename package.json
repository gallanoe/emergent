{
  "name": "emergent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "prebuild": "bun run lint && bun run lint:rust && bun run fmt:check && bun run typecheck && bun run test && bun run test:rust",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "oxlint --ignore-pattern '*.svelte'",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "fmt": "prettier --write 'src/**/*.svelte' && oxfmt",
    "fmt:check": "prettier --check 'src/**/*.svelte' && oxfmt --check",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.17",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@lezer/markdown": "^1.6.3",
    "@tauri-apps/api": "^2.10.1",
    "lucide-svelte": "^0.577.0",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/svelte": "^5.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/bun": "^1.3.10",
    "jsdom": "^26.0.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "prettier": "^3.0.0",
    "prettier-plugin-svelte": "^3.5.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.0"
  }
}
