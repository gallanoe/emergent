{
  "name": "emergent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "prebuild": "bun run lint && bun run lint:rust && bun run fmt:check && bun run typecheck",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "oxlint --ignore-pattern 'target/'",
    "lint:rust": "cargo clippy --workspace -- -D warnings",
    "fmt": "prettier --write 'src/**/*.svelte' && oxfmt",
    "fmt:check": "prettier --check 'src/**/*.svelte' && oxfmt --check",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:rust": "cargo test --workspace",
    "test:e2e": "bunx playwright test",
    "screenshot": "bun scripts/screenshot.ts"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@lucide/svelte": "^0.577.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "dompurify": "^3.3.3",
    "marked": "^17.0.4",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/bun": "^1.3.10",
    "@types/dompurify": "^3.2.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "prettier": "^3.0.0",
    "prettier-plugin-svelte": "^3.5.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.0"
  }
}
